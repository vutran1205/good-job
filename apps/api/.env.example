# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=goodjob
POSTGRES_PASSWORD=goodjob
POSTGRES_DB=goodjob

# MinIO
MINIO_ROOT_USER=goodjob
MINIO_ROOT_PASSWORD=goodjob123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# JWT
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m

# Server
API_PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# MinIO / S3 Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:3000/media
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=good-job

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
